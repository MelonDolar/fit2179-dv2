{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Days of Extreme or Catastrophic Fire Danger",
    "subtitle": "Number of Extreme/Catastrophic rated days per state per year",
    "fontSize": 14,
    "subtitleFontSize": 10,
    "color": "#f0e0d0",
    "subtitleColor": "#c0a882"
  },
  "width": 520,
  "height": 200,
  "data": {"url": "data/bushfire_incidents.json", "format": {"property": "fire_danger_days"}},
  "transform": [
    {"calculate": "datum.catastrophic + datum.extreme", "as": "extreme_plus"}
  ],
  "mark": {"type": "rect", "cornerRadius": 2},
  "encoding": {
    "x": {
      "field": "year",
      "type": "ordinal",
      "axis": {
        "title": null,
        "labelAngle": -30,
        "labelColor": "#c0a882",
        "tickColor": "#60504a",
        "domainColor": "#60504a",
        "gridColor": "transparent"
      }
    },
    "y": {
      "field": "state",
      "type": "nominal",
      "sort": ["NSW", "VIC", "QLD", "SA"],
      "axis": {
        "title": null,
        "labelColor": "#c0a882",
        "domainColor": "#60504a",
        "tickColor": "#60504a"
      }
    },
    "color": {
      "field": "extreme_plus",
      "type": "quantitative",
      "title": "Days",
      "scale": {
        "domain": [0, 30],
        "range": ["#2e1a10", "#a03010", "#e34a33", "#fff0e0"]
      },
      "legend": {
        "labelColor": "#c0a882",
        "titleColor": "#c0a882",
        "labelFontSize": 11,
        "titleFontSize": 12,
        "gradientLength": 120
      }
    },
    "tooltip": [
      {"field": "state", "title": "State"},
      {"field": "year", "title": "Year"},
      {"field": "extreme_plus", "title": "Extreme/Catastrophic Days"},
      {"field": "catastrophic", "title": "Catastrophic Days"},
      {"field": "extreme", "title": "Extreme Days"}
    ]
  },
  "config": {"background": "transparent", "view": {"stroke": null}}
}
