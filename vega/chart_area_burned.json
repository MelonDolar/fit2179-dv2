{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Area Burned in the 2019–20 Black Summer",
    "subtitle": "Hectares burned per state",
    "fontSize": 14,
    "subtitleFontSize": 10,
    "color": "#f0e0d0",
    "subtitleColor": "#c0a882"
  },
  "width": 340,
  "height": 260,
  "data": {
    "values": [
      {"state": "NSW", "area_ha": 5490000},
      {"state": "NT",  "area_ha": 4800000},
      {"state": "WA",  "area_ha": 3200000},
      {"state": "QLD", "area_ha": 2340000},
      {"state": "VIC", "area_ha": 1500000},
      {"state": "SA",  "area_ha": 210000},
      {"state": "TAS", "area_ha": 68000},
      {"state": "ACT", "area_ha": 27000}
    ]
  },
  "layer": [
    {
      "mark": {"type": "bar", "opacity": 0.9, "cornerRadiusEnd": 3},
      "encoding": {
        "y": {"field": "state", "type": "nominal", "sort": "-x", "axis": {"title": null, "labelColor": "#c0a882", "domainColor": "#60504a", "tickColor": "#60504a"}},
        "x": {
          "field": "area_ha",
          "type": "quantitative",
          "axis": {
            "title": "Hectares Burned",
            "format": "~s",
            "labelColor": "#c0a882",
            "titleColor": "#c0a882",
            "tickColor": "#60504a",
            "domainColor": "#60504a",
            "gridColor": "#3a2e28"
          }
        },
        "color": {
          "field": "area_ha",
          "type": "quantitative",
          "scale": {"scheme": "orangered"},
          "legend": null
        },
        "tooltip": [
          {"field": "state", "title": "State"},
          {"field": "area_ha", "title": "Area Burned (ha)", "format": ","}
        ]
      }
    },
    {
      "mark": {"type": "text", "align": "left", "dx": 5, "fontSize": 10, "color": "#f0d0b0"},
      "encoding": {
        "y": {"field": "state", "type": "nominal", "sort": "-x"},
        "x": {"field": "area_ha", "type": "quantitative"},
        "text": {"field": "area_ha", "type": "quantitative", "format": ",.0f"}
      }
    }
  ],
  "config": {"background": "transparent", "view": {"stroke": null}}
}
