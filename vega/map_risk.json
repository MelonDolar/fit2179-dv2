{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Fire Risk Score by State & Territory",
    "subtitle": "Bubble size = area burned in 2019–20  ·  Colour = composite risk score (out of 10)",
    "fontSize": 15,
    "subtitleFontSize": 11,
    "color": "#1a1a1a",
    "subtitleColor": "#555"
  },
  "width": 500,
  "height": 420,
  "projection": {
    "type": "mercator",
    "center": [134, -27],
    "scale": 680
  },
  "layer": [
    {
      "data": {
        "url": "data/australia_states.geojson",
        "format": {"type": "json", "property": "features"}
      },
      "mark": {
        "type": "geoshape",
        "fill": "#b5a48a",
        "stroke": "#7a6048",
        "strokeWidth": 1.2
      }
    },
    {
      "data": {
        "values": [
          {"state": "NSW",  "lat": -32.5, "lon": 146.9, "risk_score": 8.4, "total_area_burned_2019": 5490000, "avg_temp_increase": 1.4},
          {"state": "VIC",  "lat": -37.0, "lon": 144.5, "risk_score": 7.8, "total_area_burned_2019": 1500000, "avg_temp_increase": 1.2},
          {"state": "QLD",  "lat": -22.5, "lon": 144.4, "risk_score": 7.1, "total_area_burned_2019": 2340000, "avg_temp_increase": 1.1},
          {"state": "SA",   "lat": -30.5, "lon": 135.5, "risk_score": 6.9, "total_area_burned_2019": 210000,  "avg_temp_increase": 1.3},
          {"state": "WA",   "lat": -26.0, "lon": 121.0, "risk_score": 6.5, "total_area_burned_2019": 3200000, "avg_temp_increase": 1.0},
          {"state": "TAS",  "lat": -42.0, "lon": 146.5, "risk_score": 5.8, "total_area_burned_2019": 68000,   "avg_temp_increase": 0.9},
          {"state": "NT",   "lat": -19.5, "lon": 134.0, "risk_score": 5.2, "total_area_burned_2019": 4800000, "avg_temp_increase": 1.1},
          {"state": "ACT",  "lat": -35.5, "lon": 149.1, "risk_score": 8.1, "total_area_burned_2019": 27000,   "avg_temp_increase": 1.5}
        ]
      },
      "mark": {
        "type": "circle",
        "opacity": 0.82,
        "stroke": "#ffffff",
        "strokeWidth": 1.8
      },
      "encoding": {
        "longitude": {"field": "lon", "type": "quantitative"},
        "latitude":  {"field": "lat", "type": "quantitative"},
        "size": {
          "field": "total_area_burned_2019",
          "type": "quantitative",
          "title": "Area burned 2019 (ha)",
          "scale": {"range": [40, 2800]},
          "legend": {
            "orient": "bottom",
            "direction": "horizontal",
            "gradientLength": 100,
            "labelFontSize": 10,
            "titleFontSize": 11,
            "titleColor": "#1a1a1a",
            "labelColor": "#333",
            "columns": 3
          }
        },
        "color": {
          "field": "risk_score",
          "type": "quantitative",
          "title": "Risk Score",
          "scale": {"scheme": "orangered", "domain": [4, 9]},
          "legend": {
            "orient": "bottom",
            "direction": "horizontal",
            "gradientLength": 140,
            "gradientThickness": 12,
            "labelFontSize": 10,
            "titleFontSize": 11,
            "titleColor": "#1a1a1a",
            "labelColor": "#333"
          }
        },
        "tooltip": [
          {"field": "state",                 "title": "State / Territory"},
          {"field": "risk_score",             "title": "Risk Score (out of 10)"},
          {"field": "avg_temp_increase",      "title": "Temp. Increase (°C)"},
          {"field": "total_area_burned_2019", "title": "2019 Area Burned (ha)", "format": ","}
        ]
      }
    }
  ],
  "config": {"background": "transparent", "view": {"stroke": null}}
}
