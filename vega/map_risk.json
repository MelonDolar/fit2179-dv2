{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Fire Risk Score by State & Territory",
    "subtitle": "Bubble size = area burned in 2019–20 · Colour = composite risk score",
    "fontSize": 15,
    "subtitleFontSize": 11,
    "color": "#1a1a1a",
    "subtitleColor": "#555"
  },
  "width": 520,
  "height": 400,
  "projection": {
    "type": "mercator",
    "center": [134, -28],
    "scale": 700
  },
  "layer": [
    {
      "data": {
        "url": "data/australia_states.geojson",
        "format": {"type": "json", "property": "features"}
      },
      "mark": {
        "type": "geoshape",
        "fill": "#d9cfc4",
        "stroke": "#a89880",
        "strokeWidth": 1
      }
    },
    {
      "data": {
        "url": "data/climate_data.json",
        "format": {"property": "state_climate_risk"}
      },
      "mark": {
        "type": "circle",
        "opacity": 0.85,
        "stroke": "#ffffff",
        "strokeWidth": 1.5
      },
      "encoding": {
        "longitude": {"field": "lon", "type": "quantitative"},
        "latitude": {"field": "lat", "type": "quantitative"},
        "size": {
          "field": "total_area_burned_2019",
          "type": "quantitative",
          "title": "Area burned 2019 (ha)",
          "scale": {"range": [80, 3000]},
          "legend": {
            "labelFontSize": 11,
            "titleFontSize": 12,
            "orient": "bottom-right"
          }
        },
        "color": {
          "field": "risk_score",
          "type": "quantitative",
          "title": "Risk Score",
          "scale": {"scheme": "orangered", "domain": [4, 9]},
          "legend": {
            "labelFontSize": 11,
            "titleFontSize": 12,
            "gradientLength": 120,
            "orient": "bottom-left"
          }
        },
        "tooltip": [
          {"field": "state", "title": "State / Territory"},
          {"field": "risk_score", "title": "Risk Score (out of 10)"},
          {"field": "avg_temp_increase", "title": "Temp. Increase (°C)"},
          {"field": "total_area_burned_2019", "title": "2019 Area Burned (ha)", "format": ","}
        ]
      }
    }
  ],
  "config": {"background": "transparent", "view": {"stroke": null}}
}
