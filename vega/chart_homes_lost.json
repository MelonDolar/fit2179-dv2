{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Homes Lost in the 2019–20 Black Summer",
    "subtitle": "Number of residential structures destroyed, by state",
    "fontSize": 14,
    "subtitleFontSize": 10,
    "color": "#1a1a1a",
    "subtitleColor": "#555"
  },
  "width": 380,
  "height": 220,
  "data": {"url": "data/climate_data.json", "format": {"property": "homes_lost"}},
  "layer": [
    {
      "mark": {"type": "bar", "cornerRadiusEnd": 4, "opacity": 0.9},
      "encoding": {
        "y": {"field": "state", "type": "nominal", "sort": "-x", "axis": {"title": null}},
        "x": {
          "field": "homes",
          "type": "quantitative",
          "axis": {"title": "Homes Destroyed"}
        },
        "color": {
          "field": "homes",
          "type": "quantitative",
          "scale": {"scheme": "reds"},
          "legend": null
        },
        "tooltip": [
          {"field": "state", "title": "State"},
          {"field": "homes", "title": "Homes Destroyed", "format": ","}
        ]
      }
    },
    {
      "mark": {"type": "text", "align": "left", "dx": 5, "fontSize": 12, "fontWeight": "bold"},
      "encoding": {
        "y": {"field": "state", "type": "nominal", "sort": "-x"},
        "x": {"field": "homes", "type": "quantitative"},
        "text": {"field": "homes", "type": "quantitative", "format": ","}
      }
    }
  ],
  "config": {"background": "transparent", "view": {"stroke": null}}
}
