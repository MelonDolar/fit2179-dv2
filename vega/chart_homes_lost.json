{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Homes Lost in the 2019–20 Black Summer",
    "subtitle": "Number of residential structures destroyed, by state",
    "fontSize": 14,
    "subtitleFontSize": 10,
    "color": "#f0e0d0",
    "subtitleColor": "#c0a882"
  },
  "width": 300,
  "height": 220,
  "data": {"url": "data/climate_data.json", "format": {"property": "homes_lost"}},
  "layer": [
    {
      "mark": {"type": "bar", "cornerRadiusEnd": 3, "opacity": 0.9},
      "encoding": {
        "y": {
          "field": "state", "type": "nominal", "sort": "-x",
          "axis": {"title": null, "labelColor": "#c0a882", "domainColor": "#60504a", "tickColor": "#60504a"}
        },
        "x": {
          "field": "homes", "type": "quantitative",
          "axis": {
            "title": "Homes Destroyed",
            "format": ",.0f",
            "labelColor": "#c0a882",
            "titleColor": "#c0a882",
            "tickColor": "#60504a",
            "domainColor": "#60504a",
            "gridColor": "#3a2e28"
          }
        },
        "color": {
          "field": "homes", "type": "quantitative",
          "scale": {"scheme": "reds"}, "legend": null
        },
        "tooltip": [
          {"field": "state", "title": "State"},
          {"field": "homes", "title": "Homes Destroyed", "format": ","}
        ]
      }
    },
    {
      "mark": {"type": "text", "align": "left", "dx": 5, "fontSize": 11, "fontWeight": "bold", "color": "#f0d0b0"},
      "encoding": {
        "y": {"field": "state", "type": "nominal", "sort": "-x"},
        "x": {"field": "homes", "type": "quantitative"},
        "text": {"field": "homes", "type": "quantitative", "format": ","}
      }
    }
  ],
  "config": {"background": "transparent", "view": {"stroke": null}}
}
