{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Economic Toll of Bushfires (A$ millions)",
    "subtitle": "Property, livestock, agriculture losses and emergency response costs",
    "fontSize": 14,
    "subtitleFontSize": 10,
    "color": "#1a1a1a",
    "subtitleColor": "#555"
  },
  "width": 500,
  "height": 270,
  "data": {
    "url": "data/climate_data.json",
    "format": {"property": "economic_impact"}
  },
  "transform": [
    {
      "fold": ["property_loss_m", "livestock_loss_m", "agriculture_loss_m", "emergency_cost_m"],
      "as": ["category", "value"]
    },
    {
      "calculate": "{'property_loss_m': 'Property Loss', 'livestock_loss_m': 'Livestock Loss', 'agriculture_loss_m': 'Agriculture Loss', 'emergency_cost_m': 'Emergency Response'}[datum.category]",
      "as": "category_label"
    }
  ],
  "mark": {"type": "bar", "cornerRadiusEnd": 3},
  "encoding": {
    "x": {"field": "year", "type": "ordinal", "axis": {"title": null, "labelAngle": 0}},
    "y": {
      "field": "value",
      "type": "quantitative",
      "stack": "zero",
      "axis": {"title": "A$ million", "format": ",.0f"}
    },
    "color": {
      "field": "category_label",
      "type": "nominal",
      "title": "Category",
      "scale": {
        "domain": ["Property Loss", "Livestock Loss", "Agriculture Loss", "Emergency Response"],
        "range": ["#c0392b", "#8e44ad", "#d35400", "#2980b9"]
      }
    },
    "tooltip": [
      {"field": "year", "title": "Year"},
      {"field": "category_label", "title": "Category"},
      {"field": "value", "title": "Cost (A$M)", "format": ",.0f"}
    ]
  },
  "config": {"background": "transparent", "view": {"stroke": null}}
}
