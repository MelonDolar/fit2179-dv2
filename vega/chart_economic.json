{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Economic Toll of Bushfires (A$ millions)",
    "subtitle": "Use the checkboxes to show or hide cost categories",
    "fontSize": 14, "subtitleFontSize": 10,
    "color": "#f0e0d0", "subtitleColor": "#c0a882"
  },
  "width": 480, "height": 280,
  "data": {"url": "data/climate_data.json", "format": {"property": "economic_impact"}},
  "transform": [
    {"fold": ["property_loss_m","livestock_loss_m","agriculture_loss_m","emergency_cost_m"], "as": ["category","value"]},
    {"calculate": "{'property_loss_m':'Property Loss','livestock_loss_m':'Livestock Loss','agriculture_loss_m':'Agriculture Loss','emergency_cost_m':'Emergency Response'}[datum.category]", "as": "category_label"},
    {"filter": "(datum.category_label === 'Property Loss' && PropLoss) || (datum.category_label === 'Livestock Loss' && LivestockLoss) || (datum.category_label === 'Agriculture Loss' && AgriLoss) || (datum.category_label === 'Emergency Response' && Emergency)"}
  ],
  "params": [
    {"name": "PropLoss",      "value": true, "bind": {"input": "checkbox", "name": "Property Loss "}},
    {"name": "LivestockLoss", "value": true, "bind": {"input": "checkbox", "name": "Livestock Loss "}},
    {"name": "AgriLoss",      "value": true, "bind": {"input": "checkbox", "name": "Agriculture Loss "}},
    {"name": "Emergency",     "value": true, "bind": {"input": "checkbox", "name": "Emergency Response "}}
  ],
  "mark": {"type": "bar", "cornerRadiusEnd": 3},
  "encoding": {
    "x": {"field": "year", "type": "ordinal", "axis": {"title": null, "labelAngle": 0, "labelColor": "#f0d8b8", "labelFontSize": 11, "tickColor": "#60504a", "domainColor": "#60504a", "gridColor": "#3a2e28"}},
    "y": {"field": "value", "type": "quantitative", "stack": "zero", "axis": {"title": "A$ million", "format": ",.0f", "labelColor": "#c0a882", "titleColor": "#c0a882", "labelFontSize": 10, "tickColor": "#60504a", "domainColor": "#60504a", "gridColor": "#3a2e28"}},
    "color": {
      "field": "category_label", "type": "nominal", "title": "Category",
      "scale": {"domain": ["Property Loss","Livestock Loss","Agriculture Loss","Emergency Response"], "range": ["#e03535","#9b59b6","#e07820","#3498db"]},
      "legend": {"labelColor": "#f0d8b8", "titleColor": "#f0d8b8", "labelFontSize": 11, "titleFontSize": 12, "symbolSize": 120}
    },
    "tooltip": [
      {"field": "year", "title": "Year"},
      {"field": "category_label", "title": "Category"},
      {"field": "value", "title": "Cost (A$M)", "format": ",.0f"}
    ]
  },
  "config": {"background": "transparent", "view": {"stroke": null}}
}
