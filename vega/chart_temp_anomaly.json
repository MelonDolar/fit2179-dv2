{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Australia's Rising Temperatures",
    "subtitle": "Annual temperature anomaly relative to 1961–1990 baseline (°C)",
    "fontSize": 15,
    "subtitleFontSize": 11,
    "color": "#f0e0d0",
    "subtitleColor": "#c0a882"
  },
  "width": 480,
  "height": 240,
  "data": {"url": "data/climate_data.json", "format": {"property": "temp_anomaly"}},
  "layer": [
    {
      "mark": {"type": "area", "opacity": 0.15, "color": "#e8722a", "line": false}
    },
    {
      "mark": {
        "type": "line",
        "color": "#e8722a",
        "strokeWidth": 2.5,
        "point": {"filled": true, "size": 40, "color": "#e8722a"}
      }
    },
    {
      "mark": {
        "type": "rule",
        "color": "#706050",
        "strokeDash": [4, 4],
        "strokeWidth": 1
      },
      "encoding": {"y": {"datum": 0}}
    },
    {
      "transform": [{"filter": "datum.year == 2019"}],
      "mark": {
        "type": "text",
        "align": "right",
        "dx": -6,
        "dy": 14,
        "fontSize": 10.5,
        "fontWeight": "600",
        "color": "#ffb07a"
      },
      "encoding": {"text": {"value": "▲ Black Summer: +1.52°C"}}
    }
  ],
  "encoding": {
    "x": {
      "field": "year",
      "type": "ordinal",
      "axis": {
        "title": null,
        "labelAngle": -45,
        "labelColor": "#c0a882",
        "labelFontSize": 10,
        "tickColor": "#60504a",
        "domainColor": "#60504a",
        "gridColor": "#3a2e28"
      }
    },
    "y": {
      "field": "anomaly",
      "type": "quantitative",
      "axis": {
        "title": "Temp. Anomaly (°C)",
        "labelColor": "#c0a882",
        "titleColor": "#c0a882",
        "labelFontSize": 10,
        "tickColor": "#60504a",
        "domainColor": "#60504a",
        "gridColor": "#3a2e28"
      }
    },
    "tooltip": [
      {"field": "year", "title": "Year"},
      {"field": "anomaly", "title": "Anomaly (°C)"}
    ]
  },
  "config": {"background": "transparent", "view": {"stroke": null}}
}
